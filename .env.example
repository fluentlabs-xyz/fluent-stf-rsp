# Fluent STF production docker-compose environment.
#
# USAGE:
#   cp .env.example .env
#   chmod 600 .env
#   # fill in the values below
#   make compose-build
#   make compose-up
#
# SECURITY:
#   - .env is gitignored and must never be committed.
#   - `chmod 600 .env` so only root / owner can read it.
#   - Both L1_SUBMITTER_KEY and API_KEY are sensitive — rotate via updating
#     .env and `docker compose up -d --force-recreate`.

# ─── Build-time ──────────────────────────────────────────────────────────────
# Which Fluent network to build for (mainnet | testnet | devnet).
NETWORK=testnet

# ─── SECURITY NOTE ───────────────────────────────────────────────────────────
# All secrets below are delivered as environment variables, which means they
# are visible via `docker inspect fluent-proxy` to anyone with access to the
# docker socket on this host. Mitigations:
#   1. chmod 600 .env  (only owner can read the source file)
#   2. Run compose as root on a dedicated EC2 host; do not grant docker socket
#      access to unprivileged users.
#   3. Future: migrate to compose `secrets:` with file-backed delivery once
#      the Rust binaries support `*_FILE` env var indirection.

# ─── Runtime: shared secrets ─────────────────────────────────────────────────
# HTTP x-api-key header. Used by proxy (validation) and orchestrator (sent).
API_KEY="secret"

# Hex-encoded secp256k1 private key (0x-prefixed) for L1 tx signing.
# Consumed by both proxy (attestation verify tx) and orchestrator
# (preconfirmBatch tx).
L1_SUBMITTER_KEY=

# ─── Runtime: proxy-specific ─────────────────────────────────────────────────
# Bind address for the proxy HTTP server. Default 127.0.0.1:8080 keeps the
# signing endpoints on loopback only (host networking is in use).
PROXY_LISTEN_ADDR=127.0.0.1:8080

# SQLite database path for proxy state (attestation request_id, challenges).
# Inside the container this is set by Dockerfile to /var/lib/proxy/proxy.db.
PROXY_DB_PATH=/var/lib/proxy/proxy.db

# L2 (Fluent) RPC URL — used by proxy's challenge endpoints.
RPC_URL=

# ─── Runtime: L1 (shared by proxy and orchestrator) ──────────────────────────
L1_RPC_URL=
L1_ROLLUP_ADDR=0x1cF53Fd9CD0b713be29F2b41cA17A943f138727f
# L1 block where Rollup contract was deployed (lower bound for event scans).
L1_ROLLUP_DEPLOY_BLOCK=10669685

# ─── Runtime: orchestrator-specific ──────────────────────────────────────────
# Proxy base URL from orchestrator (same host as compose).
PROXY_URL=http://127.0.0.1:8080
HTTP_TIMEOUT_SECS=120

# Optional: startup L1 scan trigger (see orchestrator main.rs for semantics).
L1_START_BATCH_ID=1

# ─── Runtime: orchestrator storage ───────────────────────────────────────────
# Working directory for the forward-driver.
DATADIR=/var/lib/witness/forward-driver
# Path to redb cold storage file.
WITNESS_COLD_FILE=/var/lib/witness/forward-driver/cold.redb
# Max cold storage size in bytes (default 5 GiB).
MAX_COLD_BYTES=5368709120
# Number of L2 blocks to retain in the cold witness store. Blocks older than
# `tip - WITNESS_RETENTION_BLOCKS` are pruned on every push. `0` disables
# retention (archive mode).
WITNESS_RETENTION_BLOCKS=172800
# Max MDBX map size in bytes (default 32 GiB).
MDBX_MAX_SIZE=34359738368
# Full prune mode.
PRUNE_FULL=true
# Path to orchestrator database.
DB_PATH=/var/lib/witness/witness_orchestrator.db

# ─── Runtime: logging ────────────────────────────────────────────────────────
RUST_LOG=info

# ─── SP1 prover network (unused by docker-compose) ─────────────────
SP1_PROVER=network
SP1_PRIVATE_KEY=
